{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "react": ["./react.d.ts"],
      "react-dom": ["./react.d.ts"],
      "react/jsx-runtime": ["./react.d.ts"]
    }
  },
  "include": ["src", "react.d.ts"],
  "exclude": ["dist", "node_modules"]
}
